// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Pago {
    id                  String      @id @default(cuid())
    buyerId             String
    sellerId            String
    buyerClerkUserId    String
    sellerClerkUserId   String
    formaDePago         String
    estado              String
    pedidoId            String
    fecha               DateTime
    descripcion         String?
    monto               Decimal     @db.Decimal(10, 2)
    disputa             Disputa?
}

model Disputa {
    id                  String      @id @default(cuid())
    clerkUserId         String
    pedidoId            String      @unique
    pagoId              String      @unique
    pago                Pago        @relation(fields: [pagoId], references: [id])
    fechaDeInicio       DateTime
    fechaDeFinalizacion DateTime?
    estado              String
    descripcion         String?
}

model CredencialVendedor {
    id                String    @id @default(cuid())
    clerkUserId       String    @unique

    vendedorId        String    @unique 
    
    mercadoPagoUserId BigInt    @unique 
    
    accessToken       String    @db.Text
    refreshToken      String    @db.Text
    publicKey         String?   @db.Text
    
    expiresIn         Int
    updatedAt         DateTime  @updatedAt
    createdAt         DateTime  @default(now())
}